# Example environment variables for deployment

# Frontend (Vite)
# Point the frontend to the backend API (Netlify backend)
VITE_API_URL=https://financial-advisor-web-app.netlify.app

# Backend (Netlify environment)
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=https://financial-advisor-web-app.vercel.app,https://financial-advisor-web-app.netlify.app

# Postgres / Neon connection
# Replace with your production database URL
DATABASE_URL=postgres://user:password@host:5432/database

# JWT secret used by the backend
JWT_SECRET=super_secret_jwt_key

# Optional: news API key, Gemini API keys
NEWS_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Runtime
PORT=5000
NODE_ENV=production

# Notes:
# - This is an example file; do NOT commit real secrets. Use your platform's
#   environment variable settings (Vercel / Netlify) to set real values.